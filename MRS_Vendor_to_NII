### MRS DATA CONVERSION SCRIPT
### Created by Arijit Bhattacharya (Ph.D. Scholar, Ashoka University)
### This code utilises spec2nii toolbox, thus installation of spec2nii package is compulsory

###Installation of spec2nii (If not installed already)

pip install spec2nii 

mkdir -p /your_output_directory/NIFTI



### Philips (SDAT/SPAR) to NII

outdir="/your_output_directory"

for f in /your_input_directory/*.SDAT; do
    
    spar="${f%.SDAT}.SPAR"
    fname=$(basename "$f" .SDAT)

    spec2nii philips -j -f "$fname" -o "$outdir" "$f" "$spar"
done



### Siemens (rda) to NII

for f in /your_input_directory/*.rda; do \
  fname=$(basename "$f" .rda); \
  spec2nii rda -j -f "$fname" -o /your_output_directory/NIFTI "$f"; \
done



### Siemens (ima) to NII

for f in /your_input_directory/*.IMA; do
    fname=$(basename "$f" .IMA)
    spec2nii dicom -j -f "$fname" -o /your_output_directory/NIFTI "$f"
done



### DICOM (dcm) to NII

for f in /your_input_directory/*.dcm; do
    fname=$(basename "$f" .dcm)
    spec2nii dicom -j -f "$fname" -o /your_output_directory/NIFTI "$f"
done



### TWIX RAW (.dat) to NII

for f in /your_input_directory/*.dat; do
    fname=$(basename "$f" .dat)
    spec2nii twix -j -f "$fname" -o /your_output_directory/NIFTI "$f"
done
